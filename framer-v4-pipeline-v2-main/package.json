{
  "name": "framer-v4-pipeline-v2",
  "version": "0.18.0",
  "description": "Standalone Framer to Elementor V4 pre-build pipeline scripts",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test tests/pipeline.test.js",
    "test:e2e": "node --test tests/e2e.test.js",
    "test:all": "node --test tests/pipeline.test.js && node --test tests/e2e.test.js && node --test tests/integration.test.js",
    "test:visual": "node --test tests/visual-regression.test.js",
    "test:integration": "node --test tests/integration.test.js",
    "test:bridge": "node scripts/lib/mcp-bridge.js --self-test",
    "validate": "node scripts/framer-pre-build-validate.js",
    "preflight": "node scripts/framer-pre-build-validate.js",
    "preflight-check": "node scripts/preflight-check.js",
    "schema-validate": "node scripts/validate-v4-tree.js",
    "validate-tree": "node scripts/validate-v4-tree.js",
    "check-binding": "node scripts/verify-build-binding.js",
    "verify-binding": "node scripts/verify-build-binding.js",
    "token-extract": "node scripts/design-token-extractor.js",
    "extract-tokens": "node scripts/design-token-extractor.js",
    "gc-generate": "node scripts/generate-global-classes.js",
    "generate-gc": "node scripts/generate-global-classes.js",
    "gc-execute": "node scripts/generate-global-classes.js --execute",
    "cross-validate": "node scripts/cross-validate-sources.js",
    "patch-media": "node scripts/patch-v4-tree-media-ids.js",
    "auto-scale": "node scripts/auto-scale-responsive.js",
    "dependency-graph": "node scripts/build-dependency-graph.js",
    "convert": "node scripts/convert-xml-to-v4.js",
    "asset-queue": "node scripts/asset-to-wp-media.js",
    "asset-upload": "node scripts/asset-to-wp-media.js --execute",
    "export-mcp-plan": "node scripts/export-mcp-xml.js",
    "widget-plan": "node scripts/html-to-widget-plan.js",
    "widget-plan-execute": "node scripts/html-to-widget-plan.js --execute",
    "sync-schema": "node scripts/sync-schema.js",
    "parallel": "node scripts/parallel-pre-build.js",
    "test:mcp-mock": "node tests/integration.test.js",
    "test:schema": "node scripts/sync-schema.js --validate",
    "visual-qa": "node scripts/visual-qa.js",
    "visual-qa-a11y": "node scripts/visual-qa.js --a11y",
    "check-v4": "node scripts/check-v4-requirements.js",
    "check-v4-auto": "node scripts/check-v4-requirements.js --auto-call",
    "dedup-qa": "node scripts/deduplicate-visual-qa.js",
    "apply-gv-ids": "node scripts/design-token-extractor.js --apply-response",
    "post-build-qa": "node scripts/run-post-build-qa.js",
    "section-compare": "node scripts/section-compare.js",
    "compare:hero": "node scripts/section-compare.js --framer-url https://remarkable-interface-616594.framer.app/ --elementor-url http://solar.local/framer-e2e-test-hero/ --section hero --above-fold --open",
    "extract-components": "node scripts/extract-framer-components.js",
    "extract-interactions": "node scripts/extract-framer-interactions.js",
    "extract-forms": "node scripts/extract-framer-forms.js",
    "extract-dark-mode": "node scripts/extract-framer-dark-mode.js",
    "extract-animations": "node scripts/framer-animation-extractor.js",
    "auto-fix": "node scripts/post-build-auto-fix.js",
    "inject-code": "node scripts/inject-animation-code.js",
    "inject-animations": "node scripts/inject-animation-code.js --plan animation-plan.json",
    "inject-from-export": "node scripts/inject-animation-code.js --from-framer-export",
    "wizard-batch": "node wizard.js batch",
    "lint:version": "node --input-type=module -e \"import{readFileSync}from'node:fs';const p=JSON.parse(readFileSync('package.json','utf8'));const c=readFileSync('CHANGELOG.md','utf8');if(!c.includes(p.version)){process.stderr.write('CHANGELOG.md missing v'+p.version+'\\\\n');process.exit(1)}console.log('v'+p.version+' OK')\"",
    "measure-quality": "node scripts/measure-quality-metrics.js",
    "test:integration-live": "node --test tests/integration.test.js -- --live",
    "profile-pipeline": "node scripts/profile-pipeline.js",
    "deploy-plugin": "bash novamira-adrianv2/scripts/deploy-plugin.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "axe-core": "^4.12.1",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0"
  }
}
